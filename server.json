{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.MICONNM/openclaw-consensus-mcp",
  "title": "OpenClaw Consensus",
  "description": "9-LLM consensus answers, disagreement scoring, and cheapest-route recommendations to fight hallucinations.",
  "repository": {
    "url": "https://github.com/MICONNM/openclaw-consensus-mcp",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "openclaw-consensus-mcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "RAPIDAPI_KEY",
          "description": "Your RapidAPI key from https://rapidapi.com/yanmiayn/api/openclaw-consensus",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
